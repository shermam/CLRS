   "source": [
    "for j in range(len(a) -1):\n",
    "  smallest_index = j\n",
    "  for i in range(j+1, len(a)):\n",
    "    if a[i] < a[smallest_index]:\n",
    "      smallest_index = i\n",
    "  a[j], a[smallest_index] = a[smallest_index], a[j]"
   ]
